{
  "name": "swasthyaops-web",
  "version": "0.1.0",
  "private": true,
  "description": "SwasthyaOps AI — Command Center web app + Facility PWA (one Next.js build, role-routed; docs/08_App_Flow.md)",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint && eslint --rule '{\"no-restricted-syntax\": [\"error\", {\"selector\": \"Literal[value=/^#[0-9a-fA-F]{3,8}$/]\", \"message\": \"no-raw-colors: use theme tokens (docs/09 §3)\"}]}' src",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:a11y": "playwright test tests/a11y",
    "storybook": "storybook dev -p 6006"
  },
  "dependencies": {
    "@emotion/cache": "^11.14.0",
    "@emotion/react": "^11.13.0",
    "@emotion/styled": "^11.13.0",
    "@mui/icons-material": "^6.1.0",
    "@mui/material": "^6.1.0",
    "@mui/material-nextjs": "^9.1.1",
    "@vis.gl/react-google-maps": "^1.1.0",
    "firebase": "^10.13.0",
    "idb": "^8.0.0",
    "next": "^14.2.0",
    "next-intl": "^4.13.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "recharts": "^2.12.0",
    "uuid": "^14.0.1"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.9.0",
    "@playwright/test": "^1.46.0",
    "@testing-library/react": "^16.0.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.0",
    "openapi-typescript": "^7.3.0",
    "storybook": "^8.2.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.5.0",
    "vitest": "^4.1.10"
  }
}
